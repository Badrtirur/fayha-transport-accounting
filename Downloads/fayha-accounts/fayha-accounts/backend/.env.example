# ==========================================
# FAYHA TRANSPORTATION - ACCOUNTING SYSTEM
# Environment Configuration
# ==========================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/fayha_accounts?schema=public"

# JWT Authentication
JWT_SECRET=fayha-jwt-secret-change-in-production-2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=fayha-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Fayha Accounts <noreply@fayha-transport.sa>"

# ZATCA E-Invoicing (Phase 2)
ZATCA_ENV=sandbox
ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_COMPLIANCE_CSID=
ZATCA_COMPLIANCE_SECRET=
ZATCA_PRODUCTION_CSID=
ZATCA_PRODUCTION_SECRET=

# Company Info (used in invoices/reports)
COMPANY_NAME=Fayha Transportation
COMPANY_NAME_AR=فيحاء للنقليات
COMPANY_CR_NUMBER=1010XXXXXX
COMPANY_VAT_NUMBER=3XXXXXXXXXXXXXXX
COMPANY_ADDRESS=Riyadh, Saudi Arabia
COMPANY_PHONE=+966-11-XXX-XXXX
COMPANY_EMAIL=accounts@fayha-transport.sa

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Banks Configuration
DEFAULT_CURRENCY=SAR
FISCAL_YEAR_START=01-01
